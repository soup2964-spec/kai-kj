# Kie.ai API key for Gemini 3 Flash receipt scanning
KIE_API_KEY=your-kie-api-token-here

# Supabase (https://supabase.com/dashboard/project/fapvarebtgckjbiwheko/settings/api)
NEXT_PUBLIC_SUPABASE_URL=https://fapvarebtgckjbiwheko.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
SUPABASE_SECRET_KEY=your-supabase-service-role-secret

# Google Sheets export (optional — without this, export downloads CSV for import)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
GOOGLE_SHEETS_SHARE_EMAIL=you@example.com
# Optional dev fallback — each user connects their own CC ledger in Upload statements
GOOGLE_SHEETS_CC_LEDGER_ID=

# LangGraph receipt agent (Python service — see agent/README.md)
AGENT_SERVICE_URL=http://localhost:8000
# Base URL for agent → Next.js (Sheets, reconcile, per-user notifications)
KAI_KJ_API_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Platform Slack app (one app — each user connects their workspace/channel via OAuth)
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# Per-user email uses SMTP credentials stored in Supabase (connect in Upload statements UI)
# No platform Resend key required.
# Credit card reconciliation after GREEN path
AGENT_RECONCILE_WEBHOOK_URL=
# Monthly folder storage webhook
AGENT_STORAGE_WEBHOOK_URL=
# Accounting webhook (shared with agent QuickBooks export node)
ACCOUNTING_WEBHOOK_URL=
ACCOUNTING_WEBHOOK_SECRET=
ACCOUNTING_PROVIDER=quickbooks
