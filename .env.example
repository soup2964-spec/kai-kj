# Kie.ai API key for Gemini 3 Flash receipt scanning and AI Google Sheets column mapping
KIE_API_KEY=your-kie-api-token-here

# Clerk (https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your-clerk-publishable-key
CLERK_SECRET_KEY=your-clerk-secret-key
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_OUT_URL=/

# Supabase (https://supabase.com/dashboard/project/fapvarebtgckjbiwheko/settings/api)
NEXT_PUBLIC_SUPABASE_URL=https://fapvarebtgckjbiwheko.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
SUPABASE_SECRET_KEY=your-supabase-service-role-secret

# Google Sheets (optional — without this, export downloads CSV for import).
# This is the ONE global Google credential: a platform "robot" service account.
# Per user, each account connects their OWN sheet (CC ledger) and shares it with
# this service account's client_email, and the exported sheet is shared back to
# the email the user connects in the Integrations tab (Clerk email as fallback).
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
# Deprecated/dev-only. Leave UNSET in multi-tenant deploys — exported sheets are
# now shared with each signed-in user's connected email, not one global address.
# GOOGLE_SHEETS_SHARE_EMAIL=
# Dev-only single-tenant fallback. Leave UNSET in production — each user connects
# their own CC ledger spreadsheet in Integrations settings.
# GOOGLE_SHEETS_CC_LEDGER_ID=

# LangGraph receipt agent (Python service — see agent/README.md)
AGENT_SERVICE_URL=http://localhost:8000
# Base URL for agent → Next.js (Sheets, reconcile, per-user notifications)
KAI_KJ_API_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Platform Slack app (one app — each user connects their workspace/channel via OAuth)
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# Per-user email uses SMTP credentials stored in Supabase (connect in Upload statements UI)
# No platform Resend key required.
# Credit card reconciliation after GREEN path
AGENT_RECONCILE_WEBHOOK_URL=
# Monthly folder storage webhook
AGENT_STORAGE_WEBHOOK_URL=
# Accounting webhook (shared with agent QuickBooks export node)
ACCOUNTING_WEBHOOK_URL=
ACCOUNTING_WEBHOOK_SECRET=
ACCOUNTING_PROVIDER=quickbooks
